# Copy this file to .env. Never commit .env or share its contents.
CMD_PROVIDER=openai_compatible
CMD_MODEL=your-vision-model
CMD_BASE_URL=https://your-compatible-api.example/v1
CMD_API_KEY=replace-with-your-key
# Optional: choose a personal Obsidian vault or another default output folder.
CMD_OUTPUT_DIR=C:\Users\your-name\Documents\Your-Obsidian-Vault
